# Supabase project configuration
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-or-anon-key"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Client-side Supabase aliases used by Vite/React code
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-or-anon-key"

# Local/self-hosted job runner
JOB_RUNNER_SECRET="replace-with-a-long-random-local-secret"

# Render worker integration
CUSTOM_WORKER_SECRET="replace-with-the-same-secret-used-by-the-render-worker"
# Custom Worker asset fulfillment reads the default custom_worker provider row
# for worker_url and sends this same server-side secret with HMAC signatures.

# LLM providers for the local pipeline. At least one is required for AI tasks.
# The asset fulfillment worker may reuse the same provider key through the
# signed Studio -> Worker payload; set the same key in worker .env for direct
# worker-only smoke tests.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GROQ_API_KEY=""
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""

# Transcription providers. Gemini, OpenAI, and Groq are currently supported.
# Reuse GEMINI_API_KEY, OPENAI_API_KEY, or GROQ_API_KEY above.

# Optional real asset fulfillment providers for Review Assets.
# Calls are server-side only; never expose these through VITE_ variables.
PEXELS_API_KEY=""
PIXABAY_API_KEY=""
UNSPLASH_ACCESS_KEY=""

# Optional legacy Lovable AI gateway. Not required for self-hosted local runs.
LOVABLE_API_KEY=""
